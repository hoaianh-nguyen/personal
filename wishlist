  const [addWishOpen, setAddWishOpen] = useState(false);
  const [claimSheet, setClaimSheet] = useState(null);

  const [aName, setAName] = useState(""); const [aEmoji, setAEmoji] = useState("🎁");
  const [wText, setWText] = useState(""); const [wNote, setWNote] = useState("");
  const [wPhoto, setWPhoto] = useState(null);
  const [wPreview, setWPreview] = useState(null);
  const [wPreviewLoading, setWPreviewLoading] = useState(false);
  const [claimerName, setClaimerName] = useState("");
  const [toast, setToast] = useState({msg:"",visible:false});

  const toastT = useRef(null); const previewTimer = useRef(null); const fileRef = useRef(null);

  useEffect(()=>{ albumsRef.current = albums; },[albums]);

  const showToast = (msg) => {
    clearTimeout(toastT.current);
    setToast({msg,visible:true});
    toastT.current = setTimeout(()=>setToast(t=>({...t,visible:false})),2600);
  };

  useEffect(()=>{
    (async()=>{
      const saved = await storageGet(STORAGE_KEY);
      if (saved?.albums) { setAlbums(saved.albums); albumsRef.current=saved.albums; }
      setLoaded(true);
    })();
    const t = setInterval(async()=>{
      const saved = await storageGet(STORAGE_KEY);
      if (saved?.albums) setAlbums(saved.albums);
    },12000);
    return ()=>clearInterval(t);
  },[]);

  const persist = useCallback(async(next)=>{
    albumsRef.current=next; setAlbums(next);
    await storageSet(STORAGE_KEY,{albums:next});
  },[]);

  useEffect(()=>{
    clearTimeout(previewTimer.current);
    setWPreview(null);
    if (!isURL(wText.trim())) { setWPreviewLoading(false); return; }
    setWPreviewLoading(true);
    previewTimer.current = setTimeout(async()=>{
      const p = await fetchPreview(wText.trim());
      setWPreview(p); setWPreviewLoading(false);
    },900);
    return ()=>clearTimeout(previewTimer.current);
  },[wText]);

  const createAlbum = async()=>{
    if (!aName.trim()) return;
    const a={id:uid(),name:aName.trim(),emoji:aEmoji,colorIndex:albumsRef.current.length,items:[],createdAt:Date.now()};
    await persist([a,...albumsRef.current]);
    setAName(""); setAEmoji("🎁"); setNewAlbumOpen(false);
    showToast("✦ Collection created");
  };
  const deleteAlbum = async(id)=>{
    await persist(albumsRef.current.filter(a=>a.id!==id));
    setView("home"); showToast("Collection removed");
  };
  const addWish = async()=>{
    if (!wText.trim()&&!wPhoto) return;
    const w={id:uid(),text:wText.trim(),note:wNote.trim(),photo:wPhoto,preview:isURL(wText.trim())?wPreview:null,claimed:false,claimedBy:"",addedAt:Date.now()};
    await persist(albumsRef.current.map(a=>a.id===view?{...a,items:[w,...a.items]}:a));
    setWText(""); setWNote(""); setWPhoto(null); setWPreview(null);
    setAddWishOpen(false); showToast("✦ Idea added");
  };
  const claimWish = async(wishId)=>{
    if (!claimerName.trim()) return;
    await persist(albumsRef.current.map(a=>a.id===view?{...a,items:a.items.map(i=>i.id===wishId?{...i,claimed:true,claimedBy:claimerName.trim()}:i)}:a));
    showToast(`✦ ${claimerName} is gifting this`);
    setClaimSheet(null); setClaimerName("");
  };
  const unclaimWish = async(wishId)=>{
    await persist(albumsRef.current.map(a=>a.id===view?{...a,items:a.items.map(i=>i.id===wishId?{...i,claimed:false,claimedBy:""}:i)}:a));
    showToast("Unclaimed");
  };
  const deleteWish = async(wishId)=>{
    await persist(albumsRef.current.map(a=>a.id===view?{...a,items:a.items.filter(i=>i.id!==wishId)}:a));
    showToast("Removed");
  };
  const handlePhoto = (e)=>{
    const file=e.target.files?.[0]; if(!file) return;
    const reader=new FileReader();
    reader.onload=ev=>setWPhoto(ev.target.result);
    reader.readAsDataURL(file); e.target.value="";
  };
  const handleShare = ()=>{
    if (navigator.clipboard) navigator.clipboard.writeText(window.location.href).then(()=>showToast("✦ Link copied — share it!"));
    else showToast("Copy the page URL to share");
  };

  const currentAlbum = albums.find(a=>a.id===view);
  const allWishes = albums.flatMap(a=>a.items||[]);
  const claimedWishes = allWishes.filter(i=>i.claimed);
  const TABS = [{label:"Collections",icon:"◈"},{label:"All Ideas",icon:"◇"},{label:"Claimed",icon:"◆"}];
  const EMOJIS = ["🎁","✈️","👗","💄","📱","🍜","🎮","📚","👟","💍","🏠","🌸","💻","🎨","🐾","⚽"];

  return (
    <div style={{fontFamily:"'Space Grotesk',sans-serif",background:C.bg,minHeight:"100vh",color:C.text,position:"relative"}}>
      <style>{`
        @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap');
        *{box-sizing:border-box;margin:0;padding:0;}
        body{background:${C.bg};overflow-x:hidden;}
        ::-webkit-scrollbar{width:2px;}
        ::-webkit-scrollbar-thumb{background:rgba(255,140,0,0.3);border-radius:99px;}
        button:active{transform:scale(0.94)!important;}
        input,textarea{color-scheme:dark;}
        input::placeholder,textarea::placeholder{color:rgba(255,255,255,0.2);}
        @keyframes dotBlink{0%,100%{opacity:0.4;}50%{opacity:1;}}
        @keyframes shimmer{0%{transform:translateX(-100%);}100%{transform:translateX(200%);}}
        @keyframes fadeUp{from{opacity:0;transform:translateY(8px);}to{opacity:1;transform:none;}}
        @keyframes spin{to{transform:rotate(360deg)}}
      `}</style>

      <Background />
      <Particles />
      <SpinRings />
      <CornerBlips />

      <div style={{maxWidth:500,margin:"0 auto",minHeight:"100vh",display:"flex",flexDirection:"column",position:"relative",zIndex:2}}>

        {/* Header */}
        <div style={{padding:"18px 18px 0",position:"sticky",top:0,zIndex:50,background:"rgba(8,8,8,0.85)",backdropFilter:"blur(24px)",borderBottom:"1px solid rgba(255,140,0,0.1)"}}>
          <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",paddingBottom:14}}>
            <div style={{display:"flex",alignItems:"center",gap:10}}>
              {view!=="home" && (
                <button onClick={()=>setView("home")} style={{background:"none",border:"none",color:C.text,fontSize:20,cursor:"pointer",lineHeight:1,paddingRight:4,opacity:0.7}}>‹</button>
              )}
              <div>
                <div style={{fontSize:10,color:C.orangeText,fontWeight:700,letterSpacing:"2px",textTransform:"uppercase",marginBottom:2}}>
                  <LiveDot />{view==="home"?"Wish Board":"Collection"}
                </div>
                <div style={{fontSize:20,fontWeight:700,letterSpacing:"-0.3px"}}>
                  {view==="home" ? "My Wish Board" : currentAlbum?.name||""}
                </div>
              </div>
            </div>
            <button onClick={handleShare} style={{background:"rgba(255,140,0,0.1)",border:"1px solid rgba(255,140,0,0.25)",borderRadius:10,padding:"8px 14px",color:C.orangeText,fontSize:11,fontWeight:700,cursor:"pointer",display:"flex",alignItems:"center",gap:6,fontFamily:"inherit",letterSpacing:"0.8px"}}>
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
              SHARE
            </button>
          </div>
          {view==="home" && (
            <div style={{display:"flex",gap:2,background:"rgba(255,255,255,0.03)",borderRadius:10,padding:3,border:"1px solid rgba(255,255,255,0.05)"}}>
              {TABS.map(t=>(
                <button key={t.label} onClick={()=>setActiveTab(t.label)} style={{
                  flex:1,padding:"8px 4px",border:"none",borderRadius:7,cursor:"pointer",
                  background:activeTab===t.label?"rgba(255,140,0,0.12)":"transparent",
                  color:activeTab===t.label?C.orangeText:C.muted,
                  fontSize:11,fontWeight:700,fontFamily:"inherit",letterSpacing:"0.5px",transition:"all 0.15s",
                  borderBottom:activeTab===t.label?`2px solid ${C.orange}`:"2px solid transparent",
                }}>{t.icon} {t.label}</button>
              ))}
            </div>
          )}
        </div>

        {/* Content */}
        <div style={{flex:1,padding:"18px 16px 100px"}}>
          {view==="home" && loaded && (
            <>
              {albums.length>0 && (
                <div style={{display:"flex",gap:8,marginBottom:18}}>
                  {[{label:"COLLECTIONS",val:albums.length},{label:"IDEAS",val:allWishes.length},{label:"CLAIMED",val:claimedWishes.length}].map(s=>(
                    <GlassCard key={s.label} style={{flex:1,padding:"10px 12px",textAlign:"center"}}>
                      <div style={{fontSize:17,fontWeight:800,color:C.orangeText}}>{s.val}</div>
                      <div style={{fontSize:9,color:C.muted,letterSpacing:"1.5px",marginTop:2}}>{s.label}</div>
                    </GlassCard>
                  ))}
                </div>
              )}

              {activeTab==="Collections" && (
                albums.length===0
                  ? <div style={{textAlign:"center",paddingTop:70,animation:"fadeUp 0.4s ease"}}>
                      <div style={{fontSize:48,marginBottom:16,opacity:0.4}}>◈</div>
                      <p style={{color:C.muted,fontSize:14,lineHeight:1.8}}>No collections yet.<br/>Create your first one below.</p>
                    </div>
                  : <div style={{display:"grid",gridTemplateColumns:"repeat(2,1fr)",gap:12}}>
                      {albums.map(a=><AlbumCard key={a.id} album={a} onClick={()=>setView(a.id)} />)}
                    </div>
              )}
              {activeTab==="All Ideas" && (
                allWishes.length===0
                  ? <div style={{textAlign:"center",paddingTop:70}}><div style={{fontSize:48,marginBottom:16,opacity:0.4}}>◇</div><p style={{color:C.muted,fontSize:14}}>No ideas yet.</p></div>
                  : allWishes.map(item=>{
                      const album=albums.find(a=>a.items?.some(i=>i.id===item.id));
                      return <div key={item.id}><div style={{fontSize:10,color:C.muted,marginBottom:4,paddingLeft:2,letterSpacing:"1px"}}>{album?.emoji} {album?.name?.toUpperCase()}</div><WishCard item={item} readonly onClaim={()=>{}} onUnclaim={()=>{}} onDelete={()=>{}} /></div>;
                    })
              )}
              {activeTab==="Claimed" && (
                claimedWishes.length===0
                  ? <div style={{textAlign:"center",paddingTop:70}}><div style={{fontSize:48,marginBottom:16,opacity:0.4}}>◆</div><p style={{color:C.muted,fontSize:14}}>Nothing claimed yet.</p></div>
                  : claimedWishes.map(item=>{
                      const album=albums.find(a=>a.items?.some(i=>i.id===item.id));
                      return <div key={item.id}><div style={{fontSize:10,color:C.muted,marginBottom:4,paddingLeft:2,letterSpacing:"1px"}}>{album?.emoji} {album?.name?.toUpperCase()}</div><WishCard item={item} readonly onClaim={()=>{}} onUnclaim={()=>{}} onDelete={()=>{}} /></div>;
                    })
              )}
            </>
          )}

          {view!=="home" && currentAlbum && (
            <>
              <GlassCard orange style={{padding:16,marginBottom:20,display:"flex",gap:16,alignItems:"center"}}>
                <AlbumCover album={currentAlbum} size={72} />
                <div style={{flex:1}}>
                  <div style={{fontSize:10,color:C.orangeText,fontWeight:700,letterSpacing:"2px",marginBottom:6}}>COLLECTION</div>
                  <div style={{fontSize:20,fontWeight:700}}>{currentAlbum.name}</div>
                  <div style={{display:"flex",gap:12,marginTop:6}}>
                    <span style={{fontSize:11,color:C.muted}}>{currentAlbum.items?.length||0} ideas</span>
                    <span style={{fontSize:11,color:C.orange}}>{(currentAlbum.items||[]).filter(i=>i.claimed).length} claimed</span>
                  </div>
                </div>
                <button onClick={()=>deleteAlbum(currentAlbum.id)} style={{background:"none",border:"none",color:"rgba(255,80,80,0.5)",fontSize:18,cursor:"pointer"}}>×</button>
              </GlassCard>
              {!currentAlbum.items?.length
                ? <div style={{textAlign:"center",paddingTop:50,animation:"fadeUp 0.4s ease"}}><div style={{fontSize:46,marginBottom:12,opacity:0.4}}>◇</div><p style={{color:C.muted,fontSize:14,lineHeight:1.8}}>Empty collection.<br/>Add your first idea below.</p></div>
                : currentAlbum.items.map(item=>(
                    <WishCard key={item.id} item={item}
                      onClaim={(id,title)=>{setClaimSheet({wishId:id,title});setClaimerName("");}}
                      onUnclaim={unclaimWish} onDelete={deleteWish}
                    />
                  ))
              }
            </>
          )}
        </div>

        {/* FAB */}
        <div style={{position:"fixed",bottom:0,left:"50%",transform:"translateX(-50%)",width:"100%",maxWidth:500,padding:"12px 16px 30px",background:`linear-gradient(to top,${C.bg} 60%,transparent)`,zIndex:50}}>
          <button
            onClick={()=>view==="home"?setNewAlbumOpen(true):setAddWishOpen(true)}
            style={{
              width:"100%",padding:14,
              background:"linear-gradient(135deg,#FF8C00,#FF4500)",
              color:"#fff",border:"none",borderRadius:14,
              fontSize:14,fontWeight:700,cursor:"pointer",fontFamily:"inherit",
              letterSpacing:"1px",textTransform:"uppercase",
              boxShadow:"0 6px 28px rgba(255,140,0,0.38)",
              position:"relative",overflow:"hidden",
            }}
          >
            {view==="home" ? "✦  New Collection" : "✦  New Idea"}
          </button>
        </div>
      </div>

      {/* Sheet: New Collection */}
      <Sheet open={newAlbumOpen} onClose={()=>setNewAlbumOpen(false)} title="New Collection">
        <p style={{fontSize:11,color:C.muted,marginBottom:10,letterSpacing:"1px"}}>CHOOSE AN ICON</p>
        <div style={{display:"flex",flexWrap:"wrap",gap:8,marginBottom:16}}>
          {EMOJIS.map(e=>(
            <button key={e} onClick={()=>setAEmoji(e)} style={{fontSize:20,padding:"7px 10px",borderRadius:10,cursor:"pointer",background:aEmoji===e?"rgba(255,140,0,0.15)":"rgba(255,255,255,0.03)",border:aEmoji===e?"1.5px solid rgba(255,140,0,0.5)":"1px solid rgba(255,255,255,0.06)",transition:"all 0.15s"}}>{e}</button>
          ))}
        </div>
        <FInput value={aName} onChange={e=>setAName(e.target.value)} placeholder="Collection name…" onKeyDown={e=>e.key==="Enter"&&createAlbum()} />
        <div style={{display:"flex",gap:10,marginTop:4}}>
          <Btn ghost onClick={()=>{setNewAlbumOpen(false);setAName("");}}>Cancel</Btn>
          <Btn onClick={createAlbum} disabled={!aName.trim()} style={{flex:2}}>Create ✦</Btn>
        </div>
      </Sheet>

      {/* Sheet: New Idea */}
      <Sheet open={addWishOpen} onClose={()=>{setAddWishOpen(false);setWText("");setWNote("");setWPhoto(null);setWPreview(null);}} title="New Idea">
        <input ref={fileRef} type="file" accept="image/*" capture="environment" style={{display:"none"}} onChange={handlePhoto} />
        {wPhoto ? (
          <div style={{position:"relative",marginBottom:10}}>
            <img src={wPhoto} alt="" style={{width:"100%",height:180,objectFit:"cover",borderRadius:12,display:"block"}} />
            <button onClick={()=>setWPhoto(null)} style={{position:"absolute",top:8,right:8,background:"rgba(0,0,0,0.7)",color:"#fff",border:"none",borderRadius:99,width:26,height:26,fontSize:12,cursor:"pointer"}}>✕</button>
          </div>
        ) : (
          <button onClick={()=>fileRef.current?.click()} style={{width:"100%",padding:12,marginBottom:10,background:"rgba(255,255,255,0.02)",border:"1.5px dashed rgba(255,140,0,0.22)",borderRadius:10,color:C.muted,fontSize:12,cursor:"pointer",fontFamily:"inherit",display:"flex",alignItems:"center",justifyContent:"center",gap:8,letterSpacing:"0.5px"}}>
            📷  ADD PHOTO
          </button>
        )}
        <FInput value={wText} onChange={e=>setWText(e.target.value)} rows={3}
          placeholder="Describe your idea, or paste any link (Instagram, Shopee, Facebook, TikTok…)" />

        {wPreviewLoading && (
          <div style={{display:"flex",alignItems:"center",gap:8,padding:"4px 0 12px"}}>
            <div style={{width:13,height:13,border:"2px solid rgba(255,140,0,0.2)",borderTopColor:C.orange,borderRadius:"50%",animation:"spin 0.7s linear infinite",flexShrink:0}} />
            <span style={{fontSize:11,color:C.muted,letterSpacing:"0.5px"}}>FETCHING PREVIEW…</span>
          </div>
        )}
        {wPreview && !wPreviewLoading && (
          <GlassCard orange style={{overflow:"hidden",marginBottom:10,borderRadius:10,position:"relative"}}>
            {wPreview.image ? (
              <div style={{display:"flex"}}>
                <img src={wPreview.image} alt="" referrerPolicy="no-referrer"
                  style={{width:80,height:80,objectFit:"cover",flexShrink:0}}
                  onError={e=>e.target.style.display="none"} />
                <div style={{padding:"10px 12px",minWidth:0}}>
                  <div style={{fontSize:10,color:C.orangeText,fontWeight:700,letterSpacing:"1px",marginBottom:3}}>
                    {getPlatformIcon(wText)} {(wPreview.publisher||"").toUpperCase()}
                  </div>
                  <div style={{fontSize:13,fontWeight:600,color:C.text,lineHeight:1.35,overflow:"hidden",display:"-webkit-box",WebkitLineClamp:2,WebkitBoxOrient:"vertical"}}>
                    {wPreview.title}
                  </div>
                </div>
              </div>
            ) : wPreview.blocked ? (
              <div style={{display:"flex",alignItems:"center",gap:12,padding:"14px",background:wPreview.platformBg,position:"relative"}}>
                <div style={{position:"absolute",inset:0,background:"rgba(0,0,0,0.45)"}} />
                <img src={wPreview.logoUrl} alt="" style={{width:42,height:42,borderRadius:10,flexShrink:0,zIndex:1,position:"relative"}} onError={e=>e.target.style.display="none"} />
                <div style={{zIndex:1,position:"relative"}}>
                  <div style={{fontSize:12,fontWeight:700,color:"#fff",marginBottom:4}}>{getPlatformIcon(wText)} {getDomain(wText).toUpperCase()}</div>
                  <div style={{fontSize:11,color:"rgba(255,255,255,0.6)",lineHeight:1.5}}>
                    This platform blocks previews — tap 📷 Add Photo above to add a thumbnail manually.
                  </div>
                </div>
              </div>
            ) : null}
          </GlassCard>
        )}

        <FInput value={wNote} onChange={e=>setWNote(e.target.value)} placeholder="Note: size, color, price… (optional)" />
        <div style={{display:"flex",gap:10,marginTop:4}}>
          <Btn ghost onClick={()=>{setAddWishOpen(false);setWText("");setWNote("");setWPhoto(null);setWPreview(null);}}>Cancel</Btn>
          <Btn onClick={addWish} disabled={!wText.trim()&&!wPhoto} style={{flex:2}}>Add Idea ✦</Btn>
        </div>
      </Sheet>

      {/* Sheet: Claim */}
      <Sheet open={!!claimSheet} onClose={()=>setClaimSheet(null)} title="Claim this item">
        {claimSheet && (
          <>
            <GlassCard orange style={{padding:"10px 14px",marginBottom:16}}>
              <p style={{fontSize:13,color:C.muted,lineHeight:1.5,fontStyle:"italic"}}>
                "{(claimSheet.title||"").slice(0,60)}{(claimSheet.title||"").length>60?"…":""}"
              </p>
            </GlassCard>
            <FInput value={claimerName} onChange={e=>setClaimerName(e.target.value)}
              placeholder="Your name (e.g. Mom, Alex…)"
              onKeyDown={e=>e.key==="Enter"&&claimWish(claimSheet.wishId)} />
            <div style={{display:"flex",gap:10,marginTop:4}}>
              <Btn ghost onClick={()=>setClaimSheet(null)}>Cancel</Btn>
              <Btn onClick={()=>claimWish(claimSheet.wishId)} disabled={!claimerName.trim()} style={{flex:2}}>I'll gift this ✦</Btn>
            </div>
          </>
        )}
      </Sheet>

      <Toast msg={toast.msg} visible={toast.visible} />
    </div>
  );
}
