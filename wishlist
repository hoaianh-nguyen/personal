// ── Glass card ────────────────────────────────────
function GlassCard({ children, style={}, orange=false, onClick, hover=false }) {
  const [hov, setHov] = useState(false);
  return (
    <div
      onClick={onClick}
      onMouseEnter={()=>hover&&setHov(true)}
      onMouseLeave={()=>hover&&setHov(false)}
      style={{
        background: orange ? "rgba(255,140,0,0.07)" : C.glass,
        border: `1px solid ${orange ? "rgba(255,140,0,0.22)" : C.glassBorder}`,
        borderRadius:16, backdropFilter:"blur(20px)", WebkitBackdropFilter:"blur(20px)",
        transition:"all 0.2s cubic-bezier(0.4,0,0.2,1)",
        transform: hov ? "translateY(-3px) scale(1.01)" : "none",
        boxShadow: hov ? `0 10px 36px rgba(255,140,0,0.14),inset 0 1px 0 rgba(255,255,255,0.07)` : `inset 0 1px 0 rgba(255,255,255,0.03)`,
        cursor: onClick ? "pointer" : "default",
        position:"relative", overflow:"hidden",
        ...style,
      }}
    >
      {hov && <div style={{position:"absolute",inset:0,pointerEvents:"none",zIndex:1,background:"linear-gradient(105deg,transparent 35%,rgba(255,200,100,0.05) 50%,transparent 65%)",animation:"shimmer 0.55s ease-out"}} />}
      {children}
    </div>
  );
}

