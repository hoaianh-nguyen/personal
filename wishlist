function uid() { return Date.now().toString(36) + Math.random().toString(36).slice(2,7); }
function isURL(s) {
  try { const u = new URL((s||"").trim()); return u.protocol.startsWith("http"); }
  catch { return false; }
}
function getDomain(url) {
  try { return new URL(url).hostname.replace("www.",""); } catch { return url; }
}
function getPlatformIcon(url) {
  const d = getDomain(url);
  if (d.includes("instagram")) return "📸";
  if (d.includes("facebook")||d.includes("fb.")) return "👥";
  if (d.includes("tiktok")) return "🎵";
  if (d.includes("shopee")) return "🛍";
  if (d.includes("lazada")) return "📦";
  if (d.includes("youtube")) return "▶";
  return "🔗";
}

// ── Detect platforms that block scrapers ──────────
const BLOCKED_PLATFORMS = ["instagram.com","facebook.com","fb.com","tiktok.com","twitter.com","x.com"];
function isBlockedPlatform(url) {
  const d = getDomain(url);
  return BLOCKED_PLATFORMS.some(p => d.includes(p));
}

// ── Get logo image for a domain ───────────────────
function getLogoUrl(url) {
  const domain = getDomain(url);
  // Google's high-res favicon service
  return `https://www.google.com/s2/favicons?domain=${domain}&sz=256`;
}

// ── Platform brand colours ────────────────────────
function getPlatformBg(url) {
  const d = getDomain(url);
  if (d.includes("instagram")) return "linear-gradient(135deg,#833AB4,#FD1D1D,#F77737)";
  if (d.includes("facebook")) return "linear-gradient(135deg,#1877F2,#0D5FBF)";
  if (d.includes("tiktok"))   return "linear-gradient(135deg,#010101,#69C9D0)";
  if (d.includes("shopee"))   return "linear-gradient(135deg,#EE4D2D,#FF7337)";
  if (d.includes("lazada"))   return "linear-gradient(135deg,#F3286A,#0F146D)";
  if (d.includes("youtube"))  return "linear-gradient(135deg,#FF0000,#CC0000)";
  if (d.includes("twitter")||d.includes("x.com")) return "linear-gradient(135deg,#1DA1F2,#0D8BDA)";
  return "linear-gradient(135deg,#333,#555)";
}

// ── Fetch preview ─────────────────────────────────
async function fetchPreview(url) {
  const domain = getDomain(url);
  const blocked = isBlockedPlatform(url);

  if (!blocked) {
    // Try microlink for non-social sites (shopee, lazada, general web)
    try {
      const res = await fetch(
        `https://api.microlink.io/?url=${encodeURIComponent(url)}&timeout=8000`
      );
      const j = await res.json();
      if (j.status === "success") {
        return {
          title: j.data.title || domain,
          description: j.data.description || "",
          image: j.data.image?.url || null,
          publisher: j.data.publisher || domain,
          blocked: false,
        };
      }
    } catch {}
  }

  // Blocked platform OR microlink failed → return brand info, no image (user adds photo)
  return {
    title: domain,
    description: blocked ? "⚠️ This platform blocks link previews. Tap + Add Photo above to add a photo manually." : "",
    image: null,
    publisher: domain,
    blocked,
    logoUrl: getLogoUrl(url),
    platformBg: getPlatformBg(url),
  };
}

async function storageGet(k) {
  try { const r = await window.storage.get(k,true); return r?.value ? JSON.parse(r.value) : null; } catch { return null; }
}
async function storageSet(k,v) {
  try { await window.storage.set(k, JSON.stringify(v), true); } catch {}
}

// ── Particles ─────────────────────────────────────
function Particles() {
  const particles = Array.from({length: 18}, (_,i) => ({
    id: i,
    size: 2 + Math.random() * 3,
    x: Math.random() * 100,
    delay: Math.random() * 12,
    duration: 10 + Math.random() * 14,
    drift: (Math.random() - 0.5) * 60,
  }));
  return (
    <div style={{position:"fixed",inset:0,pointerEvents:"none",zIndex:0,overflow:"hidden"}}>
      {particles.map(p => (
        <div key={p.id} style={{
          position:"absolute",
          left:`${p.x}%`,
          bottom:"-10px",
          width:p.size,
          height:p.size,
          borderRadius:"50%",
          background:`rgba(255,140,0,${0.3 + Math.random()*0.4})`,
          boxShadow:`0 0 ${p.size*3}px rgba(255,140,0,0.6)`,
          animationName:"particleRise",
          animationDuration:`${p.duration}s`,
          animationDelay:`${p.delay}s`,
          animationTimingFunction:"ease-in-out",
          animationIterationCount:"infinite",
          // store drift as css var
        }} />
      ))}
      <style>{`
        @keyframes particleRise {
          0%   { transform: translateY(0) translateX(0) scale(1); opacity: 0; }
          10%  { opacity: 1; }
          50%  { transform: translateY(-45vh) translateX(20px) scale(1.2); }
          90%  { opacity: 0.4; }
          100% { transform: translateY(-100vh) translateX(-15px) scale(0.5); opacity: 0; }
        }
      `}</style>
    </div>
  );
}

