}

function AlbumCover({ album, size }) {
  const img = album.items?.find(i=>i.photo)?.photo || album.items?.find(i=>i.preview?.image)?.preview?.image;
  if (img) return (
    <div style={{width:size,height:size,borderRadius:12,overflow:"hidden",flexShrink:0}}>
      <img src={img} alt="" style={{width:"100%",height:"100%",objectFit:"cover"}} onError={e=>e.target.style.display="none"} />
    </div>
  );
  return (
    <div style={{
      width:size,height:size,borderRadius:12,flexShrink:0,
      background:GRADIENTS[album.colorIndex%GRADIENTS.length],
      display:"flex",alignItems:"center",justifyContent:"center",
      fontSize:typeof size==="number"?size*0.38:28,
      boxShadow:"0 4px 20px rgba(255,140,0,0.2)",
    }}>{album.emoji||"🎁"}</div>
  );
}

